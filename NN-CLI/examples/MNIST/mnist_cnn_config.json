{
  "mode": "train",
  "device": "gpu",
  "progressReports": 1000,
  "saveModelInterval": 25,
  "inputShape": { "c": 1, "h": 28, "w": 28 },
  "convolutionalLayers": [
    { "type": "conv", "numFilters": 32, "filterH": 3, "filterW": 3, "strideY": 1, "strideX": 1, "slidingStrategy": "valid" },
    { "type": "instancenorm" },
    { "type": "relu" },
    { "type": "pool", "poolType": "max", "poolH": 2, "poolW": 2, "strideY": 2, "strideX": 2 },
    { "type": "conv", "numFilters": 64, "filterH": 3, "filterW": 3, "strideY": 1, "strideX": 1, "slidingStrategy": "valid" },
    { "type": "instancenorm" },
    { "type": "relu" },
    { "type": "pool", "poolType": "max", "poolH": 2, "poolW": 2, "strideY": 2, "strideX": 2 },
    { "type": "flatten" }
  ],
  "denseLayers": [
    { "numNeurons": 256, "actvFunc": "relu" },
    { "numNeurons": 10, "actvFunc": "softmax" }
  ],
  "train": {
    "numEpochs": 10,
    "batchSize": 512,
    "learningRate": 0.001,
    "optimizer": {
      "type": "adam"
    },
    "augmentationFactor": 0,
    "augmentationProbability": 0.5,
    "augmentationTransforms": {
      "horizontalFlip": false,
      "rotation": 10.0,
      "translation": 0.1,
      "brightness": 0.05,
      "contrast": 0.1,
      "gaussianNoise": 0.02
    }
  }
}

