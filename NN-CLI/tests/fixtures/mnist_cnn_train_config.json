  "denseLayersConfig": [
    { "numNeurons": 10, "actvFunc": "softmax" }
  ],
  "costFunctionConfig": {
    "type": "crossEntropy"
  },
  "trainingConfig": {
    "numEpochs": 10,
    "batchSize": 64,
    "learningRate": 0.001,
    "optimizer": { "type": "adam" }
  }
